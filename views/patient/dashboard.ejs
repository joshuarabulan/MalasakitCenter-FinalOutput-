<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Malasakit Center | Patient Dashboard</title>
    <link rel="icon" type="image/png" href="/img/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
</head>
<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --red: #c0392b;
            --red-dark: #922b21;
            --red-light: #f1948a;
            --cream: #fdf6f0;
            --warm-white: #fffaf7;
            --paper: #f7ede4;
            --ink: #1c1008;
            --ink-mid: #4a3728;
            --ink-soft: #8a7060;
            --gold: #c8963a;
            --gold-light: #f0d080;
            --sage: #5a7a60;
            --success: #2e7d52;
            --warning: #b5651d;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --shadow-sm: 0 2px 8px rgba(28, 16, 8, .08);
            --shadow-md: 0 8px 32px rgba(28, 16, 8, .12);
            --shadow-lg: 0 20px 60px rgba(28, 16, 8, .16);
        }

        body {
            font-family: 'Sora', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            background: var(--red-dark);
            background-image: linear-gradient(135deg, var(--red-dark) 0%, var(--red) 60%, #a93226 100%);
            color: #fff;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 24px rgba(146, 43, 33, .4);
        }

        .nav-inner {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        .nav-logo {
            width: 38px;
            height: 38px;
            background: rgba(255, 255, 255, .18);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .nav-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.1rem;
        }

        .nav-badge {
            display: none;
            background: rgba(255, 255, 255, .15);
            border: 1px solid rgba(255, 255, 255, .25);
            font-size: .7rem;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 100px;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }

        .nav-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 255, 255, .12);
            border: 1px solid rgba(255, 255, 255, .2);
            color: #fff;
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
        }

        .nav-btn:hover {
            background: rgba(255, 255, 255, .22);
            transform: translateY(-1px);
        }

        .nav-user span {
            display: inline;
        }

        .nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, .1);
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: 999px;
            padding: 5px 12px 5px 6px;
        }

        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            overflow: hidden;
            background: rgba(255, 255, 255, .18);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        .nav-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .notif-wrapper {
            position: relative;
        }

        .notif-dot {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background: var(--gold-light);
            border-radius: 50%;
        }

        /* Page Header */
        .page-header {
            max-width: 1280px;
            margin: 28px auto 0;
            padding: 0 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .header-eyebrow {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--red);
            font-weight: 700;
        }

        .header-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            line-height: 1.2;
        }

        .header-title em {
            color: var(--red);
            font-style: italic;
        }

        .header-sub {
            color: var(--ink-mid);
            font-size: 0.85rem;
        }

        .header-date {
            background: var(--warm-white);
            padding: 10px 16px;
            border-radius: 30px;
            font-size: 0.8rem;
            border: 1px solid rgba(28, 16, 8, .06);
            display: inline-block;
            width: fit-content;
        }

        /* Stats Cards */
        .stats-strip {
            max-width: 1280px;
            margin: 24px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 14px;
        }

        .stat-card {
            background: var(--warm-white);
            border-radius: var(--radius-lg);
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: var(--shadow-sm);
            border: 1px solid rgba(28, 16, 8, .05);
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            background: rgba(192, 57, 43, .1);
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: var(--red);
        }

        .stat-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--ink-soft);
        }

        .stat-value {
            font-size: 1.6rem;
            font-weight: 800;
            line-height: 1.2;
        }

        /* Action Cards */
        .actions-grid {
            max-width: 1280px;
            margin: 24px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }

        @media (min-width: 640px) {
            .actions-grid {
                grid-template-columns: 1fr 1fr;
            }
            .nav-badge {
                display: inline-block;
            }
            .nav-btn span {
                display: inline;
            }
            .header-title {
                font-size: 2.6rem;
            }
            .page-header {
                flex-direction: row;
                justify-content: space-between;
                align-items: flex-end;
            }
        }

        .action-card {
            background: var(--warm-white);
            border-radius: var(--radius-xl);
            padding: 24px;
            cursor: pointer;
            transition: all 0.25s ease;
            border: 1px solid rgba(28, 16, 8, .06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .action-card.primary {
            background: linear-gradient(145deg, var(--warm-white), #fff5ef);
            border-left: 4px solid var(--red);
        }

        .action-icon {
            width: 48px;
            height: 48px;
            background: rgba(192, 57, 43, .1);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--red);
            margin-bottom: 12px;
        }

        .action-title {
            font-weight: 800;
            font-size: 1.2rem;
        }

        .action-sub {
            font-size: 0.75rem;
            color: var(--ink-soft);
            margin-top: 6px;
        }

        .action-link {
            font-weight: 600;
            color: var(--red);
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 12px;
        }

        /* Table Section */
        .table-section {
            max-width: 1280px;
            margin: 24px auto 40px;
            padding: 0 20px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .section-title {
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .dot {
            width: 8px;
            height: 8px;
            background: var(--red);
            border-radius: 50%;
            display: inline-block;
        }

        .section-badge {
            background: var(--paper);
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .table-wrap {
            overflow-x: auto;
            border-radius: var(--radius-lg);
            background: var(--warm-white);
            border: 1px solid rgba(28, 16, 8, .06);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.8rem;
        }

        th {
            text-align: left;
            padding: 14px 12px;
            background: var(--paper);
            font-weight: 700;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid rgba(28, 16, 8, .05);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .status-pill.waiting {
            background: #fff3e0;
            color: var(--warning);
        }

        .status-pill.approved {
            background: #e3f5ec;
            color: var(--success);
        }

        .status-pill.declined {
            background: #fee;
            color: var(--red);
        }

        .tbl-btn {
            background: none;
            border: none;
            padding: 4px 8px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--red);
            transition: all 0.2s;
        }

        .tbl-btn:hover {
            background: rgba(192, 57, 43, .1);
        }

        /* Modals */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
            z-index: 200;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-box {
            background: var(--warm-white);
            border-radius: var(--radius-xl);
            max-width: 500px;
            width: 100%;
            max-height: 85vh;
            overflow-y: auto;
            padding: 24px;
        }

        .modal-box.wide {
            max-width: 800px;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .settings-field label {
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--ink-mid);
            margin-bottom: 6px;
        }

        .settings-field input {
            width: 100%;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid rgba(28, 16, 8, 0.12);
            font-family: 'Sora', sans-serif;
            background: #fff;
        }

        .settings-note {
            margin-top: 6px;
            font-size: 0.72rem;
            color: var(--ink-soft);
        }

        .settings-avatar-card {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px;
            border-radius: 20px;
            background: var(--paper);
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .settings-avatar-preview {
            width: 84px;
            height: 84px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(145deg, var(--red), var(--red-dark));
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 700;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        .settings-avatar-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .modal-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.3rem;
            margin-bottom: 16px;
        }

        /* Toast Notifications */
        .toast {
            position: fixed;
            bottom: 20px;
            left: 20px;
            right: 20px;
            background: var(--ink);
            color: white;
            padding: 14px 18px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 300;
            transform: translateY(100px);
            transition: transform 0.2s ease;
            box-shadow: var(--shadow-lg);
        }

        .toast.show {
            transform: translateY(0);
        }

        @media (min-width: 640px) {
            .toast {
                left: auto;
                right: 24px;
                bottom: 24px;
                max-width: 360px;
            }

            .settings-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .btn-row {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .btn {
            padding: 10px 18px;
            border-radius: 40px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-primary {
            background: var(--red);
            color: white;
        }

        .btn-primary:hover {
            background: var(--red-dark);
        }

        .btn-ghost {
            background: transparent;
            border: 1px solid rgba(0, 0, 0, 0.1);
        }

        .btn-ghost:hover {
            background: rgba(0, 0, 0, 0.05);
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--ink-soft);
        }

        .search-input {
            width: 100%;
            padding: 10px 14px;
            border-radius: 40px;
            border: 1px solid rgba(0, 0, 0, 0.1);
            font-family: 'Sora', sans-serif;
            margin-bottom: 16px;
        }

        .hidden {
            display: none !important;
        }
    </style>
<body>
<div id="toastWrap"></div>

<!-- Navigation -->
<nav>
    <div class="nav-inner">
        <div class="nav-brand">
            <div class="nav-logo"><i class='bx bx-heart-circle'></i></div>
            <span class="nav-title">Malasakit Center</span>
            <span class="nav-badge">Patient Portal</span>
        </div>
        <div class="nav-actions">
            <div class="notif-wrapper">
                <button class="nav-btn" id="notifBtn">
                    <i class='bx bx-bell'></i>
                    <span>Alerts</span>
                    <div class="notif-dot" id="notifDot" style="display:none"></div>
                </button>
            </div>
            <div class="nav-user">
                <div class="nav-avatar">
                    <% if (user && user.avatar) { %>
                        <img src="/uploads/avatars/<%= user.avatar %>" alt="Profile photo">
                    <% } else { %>
                        <span><%= user && user.name ? user.name.charAt(0) : 'U' %></span>
                    <% } %>
                </div>
                <span id="currentUserName"><%= user ? user.name : 'Loading...' %></span>
            </div>
            <button class="nav-btn" onclick="openModal('settingsModal')">
                <i class='bx bx-cog'></i>
                <span>Settings</span>
            </button>
            <button class="nav-btn" onclick="openModal('logoutModal')">
                <i class='bx bx-log-out'></i>
                <span>Logout</span>
            </button>
        </div>
    </div>
</nav>

<!-- Header -->
<div class="page-header">
    <div>
        <div class="header-eyebrow">Patient Dashboard</div>
        <h1 class="header-title">Medical Assistance<br><em>Made Simple.</em></h1>
        <p class="header-sub">Track, submit, and manage your medical assistance requests seamlessly.</p>
    </div>
    <div class="header-date">
        <i class='bx bx-calendar'></i>
        <strong id="currentDate"></strong>
    </div>
</div>

<!-- Stats -->
<div class="stats-strip" id="statsContainer">
    <div class="stat-card">
        <div class="stat-icon"><i class='bx bx-loader-circle'></i></div>
        <div>
            <div class="stat-label">Total Requests</div>
            <div class="stat-value">-</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class='bx bx-time-five'></i></div>
        <div>
            <div class="stat-label">Pending Review</div>
            <div class="stat-value">-</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class='bx bx-check-shield'></i></div>
        <div>
            <div class="stat-label">Approved Cases</div>
            <div class="stat-value">-</div>
        </div>
    </div>
</div>

<!-- Action Cards -->
<div class="actions-grid">
    <div class="action-card primary" onclick="window.location.href='/patient/sheet'">
        <div>
            <div class="action-icon"><i class='bx bx-plus-medical'></i></div>
            <div class="action-title">Medical Assistance<br>Request</div>
            <div class="action-sub">Submit a new request for medical aid. Secure and fast.</div>
            <div class="action-link">Request Now <i class='bx bx-right-arrow-alt'></i></div>
        </div>
    </div>
    <div class="action-card secondary" onclick="openModal('recordsModal')">
        <div>
            <div class="action-icon"><i class='bx bx-clipboard'></i></div>
            <div class="action-title">Request<br>Records</div>
            <div class="action-sub">View history, track status, and manage your submissions.</div>
            <div class="action-link">Browse Records <i class='bx bx-chevron-right'></i></div>
        </div>
    </div>
</div>

<!-- Recent Requests Table -->
<div class="table-section">
    <div class="section-header">
        <div class="section-title"><span class="dot"></span> Recently Submitted Requests</div>
        <span class="section-badge">Latest 5 entries</span>
    </div>
    <div class="table-wrap">
        <table>
            <thead>
                <tr><th>Full Name</th><th>Medical Assistance</th><th>Status</th><th>Actions</th>
            </thead>
            <tbody id="recentTableBody">
                <tr><td colspan="4" class="empty-state"><i class='bx bx-loader-alt'></i> Loading requests...</td>
            </tbody>
        </table>
    </div>
</div>

<!-- Modals -->
<div class="modal-overlay" id="logoutModal">
    <div class="modal-box" style="text-align:center">
        <div style="display:flex;justify-content:center;margin-bottom:16px;">
            <div class="settings-avatar-preview" style="width:72px;height:72px;margin:0;">
                <% if (user && user.avatar) { %>
                    <img src="/uploads/avatars/<%= user.avatar %>" alt="Profile photo">
                <% } else { %>
                    <span><%= user && user.name ? user.name.charAt(0) : 'U' %></span>
                <% } %>
            </div>
        </div>
        <div class="modal-title">Confirm Logout</div>
        <p style="margin:10px 0 20px">Are you sure you want to leave?</p>
        <div class="btn-row">
            <button class="btn btn-ghost" onclick="closeModal('logoutModal')">Cancel</button>
            <a href="/logout" class="btn btn-primary" style="text-decoration:none">Yes, Logout</a>
        </div>
    </div>
</div>

<div class="modal-overlay" id="settingsModal">
    <div class="modal-box wide">
        <div class="modal-title">Account Settings</div>
        <div class="settings-avatar-card">
            <div class="settings-avatar-preview">
                <img
                    src="<%= user && user.avatar ? `/uploads/avatars/${user.avatar}` : '' %>"
                    id="patientAvatarPreview"
                    alt="Profile preview"
                    class="<%= user && user.avatar ? '' : 'hidden' %>"
                >
                <span id="patientAvatarFallback" class="<%= user && user.avatar ? 'hidden' : '' %>"><%= user && user.name ? user.name.charAt(0) : 'U' %></span>
            </div>
            <div>
                <strong style="display:block;margin-bottom:4px;">Profile Picture</strong>
                <p style="font-size:.8rem;color:var(--ink-soft);">Update your account photo, name, email, and password.</p>
            </div>
        </div>
        <form action="/settings" method="POST" enctype="multipart/form-data" id="patientSettingsForm">
            <div class="settings-grid">
                <div class="settings-field" style="grid-column: 1 / -1;">
                    <label for="patientAvatarInput">Profile Picture</label>
                    <input type="file" id="patientAvatarInput" name="avatar" accept="image/png,image/jpeg,image/jpg,image/webp,image/gif">
                    <div class="settings-note">PNG, JPG, WEBP, or GIF up to 3 MB.</div>
                </div>
                <div class="settings-field">
                    <label for="patientNameInput">Name</label>
                    <input type="text" id="patientNameInput" name="name" value="<%= user ? user.name : '' %>" required>
                </div>
                <div class="settings-field">
                    <label for="patientEmailInput">Email</label>
                    <input type="email" id="patientEmailInput" name="email" value="<%= user ? user.email : '' %>" required>
                </div>
                <div class="settings-field">
                    <label for="patientPasswordInput">New Password</label>
                    <input type="password" id="patientPasswordInput" name="password" placeholder="Leave blank to keep current password">
                    <div class="settings-note">Password must be at least 6 characters.</div>
                </div>
                <div class="settings-field">
                    <label for="patientConfirmPasswordInput">Confirm New Password</label>
                    <input type="password" id="patientConfirmPasswordInput" name="confirmPassword" placeholder="Re-enter new password">
                </div>
            </div>
            <div id="patientSettingsError" class="settings-note" style="color:#b42318;margin-top:12px;display:none;"></div>
            <div class="btn-row">
                <button type="button" class="btn btn-ghost" onclick="closeModal('settingsModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="recordsModal">
    <div class="modal-box wide">
        <div class="modal-title"><i class='bx bx-clipboard'></i> All Requests</div>
        <input type="text" id="recordSearch" class="search-input" placeholder="Search by name or email..." onkeyup="filterRecords()">
        <div style="overflow-x:auto">
            <table style="width:100%">
                <thead>
                    <tr><th>Name</th><th>Assistance</th><th>Status</th><th>Date</th><th>Actions</th></tr>
                </thead>
                <tbody id="recordsBody">
                    <tr><td colspan="5" class="empty-state">Loading records...</td></tr>
                </tbody>
            </table>
        </div>
        <div class="btn-row">
            <button class="btn btn-ghost" onclick="closeModal('recordsModal')">Close</button>
        </div>
    </div>
</div>

<script>
    // ============================================
    // PATIENT DASHBOARD
    // Server-rendered data with client-side rendering
    // ============================================
    
    const user = <%- JSON.stringify(user ? { id: user.id, name: user.name } : { id: null, name: 'Guest' }).replace(/</g, '\\u003c') %>;
    const initialRequests = <%- JSON.stringify(requests || []).replace(/</g, '\\u003c') %>;
    const initialNotifications = <%- JSON.stringify(notifications || []).replace(/</g, '\\u003c') %>;
    
    let allRequests = Array.isArray(initialRequests) ? initialRequests : [];
    let allNotifications = Array.isArray(initialNotifications) ? initialNotifications : [];
    
    // ========== HELPER FUNCTIONS ==========
    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    function showToast(type, title, msg) {
        const wrap = document.getElementById('toastWrap');
        if (!wrap) return;
        const t = document.createElement('div');
        t.className = 'toast';
        const icon = type === 'success' ? 'bx-check-circle' : (type === 'error' ? 'bx-error-circle' : 'bx-info-circle');
        t.innerHTML = `<i class='bx ${icon}'></i><div><strong>${title}</strong><br><span style="font-size:12px;">${msg}</span></div>`;
        wrap.appendChild(t);
        setTimeout(() => t.classList.add('show'), 10);
        setTimeout(() => {
            t.classList.remove('show');
            setTimeout(() => t.remove(), 300);
        }, 3000);
    }
    
    function openModal(id) {
        const m = document.getElementById(id);
        if (m) m.style.display = 'flex';
    }
    
    function closeModal(id) {
        const m = document.getElementById(id);
        if (m) m.style.display = 'none';
        if (id === 'settingsModal') {
            const error = document.getElementById('patientSettingsError');
            const avatarInput = document.getElementById('patientAvatarInput');
            const password = document.getElementById('patientPasswordInput');
            const confirm = document.getElementById('patientConfirmPasswordInput');
            if (error) {
                error.style.display = 'none';
                error.textContent = '';
            }
            if (avatarInput) avatarInput.value = '';
            if (password) password.value = '';
            if (confirm) confirm.value = '';
        }
    }
    
    function normalizeStatus(status) {
        return String(status || 'waiting').trim().toLowerCase();
    }
    
    function statusPill(status) {
        const normalizedStatus = normalizeStatus(status);
        const labels = {
            waiting: 'Pending',
            pending: 'Pending',
            approved: 'Approved',
            declined: 'Declined',
            rejected: 'Declined'
        };
        const displayText = labels[normalizedStatus] || escapeHtml(String(status || 'Pending'));
        return `<span class="status-pill ${normalizedStatus}">${displayText}</span>`;
    }
    
    function syncDashboardData() {
        refreshStats();
        renderRecent();
        renderRecordsTable();
        updateNotificationDot();
    }
    
    function refreshStats() {
        const total = allRequests.length;
        const pending = allRequests.filter(r => {
            const status = normalizeStatus(r.status);
            return status === 'waiting' || status === 'pending';
        }).length;
        const approved = allRequests.filter(r => normalizeStatus(r.status) === 'approved').length;
        
        document.getElementById('statsContainer').innerHTML = `
            <div class="stat-card">
                <div class="stat-icon"><i class='bx bx-folder-open'></i></div>
                <div><div class="stat-label">Total Requests</div><div class="stat-value">${total}</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class='bx bx-time-five'></i></div>
                <div><div class="stat-label">Pending Review</div><div class="stat-value">${pending}</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class='bx bx-check-shield'></i></div>
                <div><div class="stat-label">Approved Cases</div><div class="stat-value">${approved}</div></div>
            </div>
        `;
    }
    
    function getUnreadNotifications() {
        return allNotifications.filter(notification => Number(notification.is_read) !== 1);
    }
    
    function updateNotificationDot() {
        const dot = document.getElementById('notifDot');
        if (dot) {
            dot.style.display = getUnreadNotifications().length > 0 ? 'block' : 'none';
        }
    }
    
    function renderRecent() {
        const tbody = document.getElementById('recentTableBody');
        const recent = [...allRequests]
            .sort((a, b) => new Date(b.created_at || 0) - new Date(a.created_at || 0))
            .slice(0, 5);
        
        if (!recent.length) {
            tbody.innerHTML = '<tr><td colspan="4" class="empty-state"><i class="bx bx-folder-open"></i><p>No requests yet. Click "Request Now" to submit.</p></td></tr>';
            return;
        }
        
        tbody.innerHTML = recent.map(r => `
            <tr>
                <td class="td-name">${escapeHtml(r.fullname || r.full_name || 'N/A')}</td>
                <td class="td-assist">${escapeHtml((r.med_assistance || r.medical_assistance || '').substring(0, 45))}</td>
                <td>${statusPill(r.status)}</td>
                <td><button class="tbl-btn" onclick="viewRequest(${r.id})"><i class='bx bx-show-alt'></i> View Form</button></td>
            </tr>
        `).join('');
    }
    
    function renderRecordsTable(filter = '') {
        const filtered = allRequests.filter(r => {
            const searchTerm = filter.toLowerCase();
            return !filter || 
                (r.fullname && r.fullname.toLowerCase().includes(searchTerm)) ||
                (r.full_name && r.full_name.toLowerCase().includes(searchTerm)) ||
                (r.email && r.email.toLowerCase().includes(searchTerm));
        });
        
        const tbody = document.getElementById('recordsBody');
        if (!filtered.length) {
            tbody.innerHTML = '<tr><td colspan="5" class="empty-state">No records found</td></tr>';
            return;
        }
        
        tbody.innerHTML = filtered.map(r => `
            <tr>
                <td style="font-weight:600">${escapeHtml(r.fullname || r.full_name || 'N/A')}</td>
                <td style="max-width:150px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escapeHtml((r.med_assistance || r.medical_assistance || '').substring(0, 30))}</td>
                <td>${statusPill(r.status)}</td>
                <td style="font-size:.75rem;">${r.created_at ? new Date(r.created_at).toLocaleDateString() : 'N/A'}</td>
                <td><button class="tbl-btn" onclick="viewRequest(${r.id})">View Form</button></td>
            </tr>
        `).join('');
    }
    
    function filterRecords() {
        const searchValue = document.getElementById('recordSearch').value.toLowerCase();
        renderRecordsTable(searchValue);
    }
    
    async function legacyViewRequest(id) {
        const request = allRequests.find(r => r.id === id);
        if (!request) {
            showToast('error', 'Error', 'Request not found');
            return;
        }
        
        // Show detailed info in a nice alert (can be replaced with modal)
        const details = `
            REQUEST DETAILS
            ─────────────────
            Patient: ${request.fullname || request.full_name}
            Contact: ${request.contact_number || request.patient_contact || 'N/A'}
            Email: ${request.email || request.patient_email || 'N/A'}
            Assistance: ${request.med_assistance || request.medical_assistance || 'N/A'}
            Status: ${request.status || 'Pending'}
            Concern: ${request.concern || request.medical_concern || 'N/A'}
            Date: ${request.created_at ? new Date(request.created_at).toLocaleString() : 'N/A'}
        `;
        alert(details);
        showToast('info', 'Request Details', `Viewing request for ${escapeHtml(request.fullname || request.full_name)}`);
    }
    
    // ========== NOTIFICATION HANDLERS ==========
    function legacyCheckNotifications() {
        updateNotificationDot();
    }
    
    function viewRequest(id) {
        const request = allRequests.find(r => r.id === id);
        if (!request) {
            showToast('error', 'Error', 'Request not found');
            return;
        }

        const viewUrl = `/patient/request/${id}/view`;
        window.open(viewUrl, '_blank', 'noopener');
        showToast('info', 'View Form', `Opening the submitted form for ${escapeHtml(request.fullname || request.full_name || 'Patient')}`);
    }
    
    function checkNotifications() {
        updateNotificationDot();
    }
    
    // ========== INITIALIZATION ==========
    function init() {
        // Set current date
        const dateElem = document.getElementById('currentDate');
        if (dateElem) {
            dateElem.innerText = new Date().toLocaleDateString('en-PH', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });
        }
        
        // Set username
        const userNameSpan = document.getElementById('currentUserName');
        if (userNameSpan) {
            userNameSpan.innerText = user.name;
        }
        
        // Load data if user is logged in
        if (user.id !== null) {
            syncDashboardData();
        } else {
            // Guest mode
            document.getElementById('recentTableBody').innerHTML = '<tr><td colspan="4" class="empty-state"><i class="bx bx-lock"></i><p>Please log in to view your requests</p></td></tr>';
            showToast('info', 'Welcome', 'Please log in to access all features');
        }
    }
    
    // Make functions global for onclick handlers
    window.openModal = openModal;
    window.closeModal = closeModal;
    window.filterRecords = filterRecords;
    window.viewRequest = viewRequest;
    
    // Start the app
    init();

    const patientAvatarInput = document.getElementById('patientAvatarInput');
    if (patientAvatarInput) {
        patientAvatarInput.addEventListener('change', function (event) {
            const file = event.target.files && event.target.files[0];
            const preview = document.getElementById('patientAvatarPreview');
            const fallback = document.getElementById('patientAvatarFallback');
            if (!file || !preview || !fallback) return;

            const reader = new FileReader();
            reader.onload = function (loadEvent) {
                preview.src = loadEvent.target.result;
                preview.classList.remove('hidden');
                fallback.classList.add('hidden');
            };
            reader.readAsDataURL(file);
        });
    }

    const patientSettingsForm = document.getElementById('patientSettingsForm');
    if (patientSettingsForm) {
        patientSettingsForm.addEventListener('submit', function (event) {
            const password = document.getElementById('patientPasswordInput');
            const confirm = document.getElementById('patientConfirmPasswordInput');
            const error = document.getElementById('patientSettingsError');
            const passwordValue = password ? password.value : '';
            const confirmValue = confirm ? confirm.value : '';

            if (passwordValue || confirmValue) {
                if (passwordValue !== confirmValue) {
                    event.preventDefault();
                    error.textContent = 'Passwords do not match.';
                    error.style.display = 'block';
                    return;
                }

                if (passwordValue.length > 0 && passwordValue.length < 6) {
                    event.preventDefault();
                    error.textContent = 'Password must be at least 6 characters.';
                    error.style.display = 'block';
                    return;
                }
            }

            if (error) {
                error.style.display = 'none';
                error.textContent = '';
            }
        });
    }
    
    // Notification button handler
    const notifBtn = document.getElementById('notifBtn');
    if (notifBtn) {
        notifBtn.addEventListener('click', () => {
            const unreadNotifications = getUnreadNotifications();
            if (unreadNotifications.length === 0) {
                showToast('info', 'Notifications', 'No new notifications');
                return;
            }
            
            const latestNotification = unreadNotifications[0];
            const latestMessage = latestNotification.message || latestNotification.title || `You have ${unreadNotifications.length} unread notification(s).`;
            showToast('info', 'Notifications', latestMessage);
        });
    }
</script>
</body>
</html>
