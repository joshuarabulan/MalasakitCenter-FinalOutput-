<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Unified Intake Sheet - Admin View</title>
        <link rel="stylesheet" href="/css/admin/print-intake.css">
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()" class="btn-print">
            <i class="fas fa-print"></i> Print
        </button>
        <button onclick="downloadAsPDF()" class="btn-download">
            <i class="fas fa-download"></i> Download PDF
        </button>
        <button onclick="window.close()" class="btn-close">
            <i class="fas fa-times"></i> Close
        </button>
    </div>

    <div class="container">
        <div class="admin-info">
            <h3>ADMIN VIEW - Intake Sheet Information</h3>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; font-size: 11px;">
                <div><strong>Intake ID:</strong> <%= intake.id %></div>
                <div><strong>User ID:</strong> <%= intake.user_id %></div>
                <div><strong>Submitted By:</strong> <%= intake.user_fullname || 'N/A' %></div>
                <div><strong>Submitted Date:</strong> <%= new Date(intake.created_at).toLocaleString() %></div>
                <div><strong>Last Updated:</strong> <%= new Date(intake.updated_at).toLocaleString() %></div>
                <div><strong>Status:</strong> 
                    <span style="font-weight: bold; color: 
                        <%= intake.request_status === 'approved' ? 'green' : 
                           intake.request_status === 'denied' ? 'red' : 
                           intake.request_status === 'under_review' ? 'orange' : 'blue' %>">
                        <%= intake.request_status.toUpperCase() %>
                    </span>
                </div>
            </div>
        </div>

        <div class="header">
            <div class="logo-row">
                <img src="/uploads/DOH.png" alt="DOH Logo" onerror="this.style.display='none'">
                <img src="/uploads/Philhealth.png" alt="PhilHealth Logo" onerror="this.style.display='none'">
                <img src="/uploads/PCSO.png" alt="PCSO Logo" onerror="this.style.display='none'">
                <img src="/uploads/DSWD.png" alt="DSWD Logo" onerror="this.style.display='none'">
                <img src="/uploads/MALASAKITCENTER.png" alt="Malasakit Logo" onerror="this.style.display='none'">
            </div>
            <h2>Unified Intake Sheet<br>Malasakit Center</h2>
        </div>

        <!-- PhilHealth & Hospital No. -->
        <div class="section">
            <table class="no-border">
                <tr>
                    <td>PhilHealth Identification No.: 
                        <span class="data-field"><%= intake.philhealth_no || 'N/A' %></span>
                        <small>(Numbers only)</small>
                    </td>
                    <td>Hospital No.: 
                        <span class="data-field"><%= intake.hospital_no || 'N/A' %></span>
                        <small>(Numbers only)</small>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Intake Details -->
        <div class="section">
            <table class="no-border">
                <tr>
                    <td>Date of Intake/Interview: 
                        <span class="data-field"><%= intake.intake_date ? new Date(intake.intake_date).toLocaleDateString() : 'N/A' %></span>
                        <small>(Petsa ng Interbyu)</small>
                    </td>
                    <td>Time of Interview: 
                        <span class="data-field"><%= intake.intake_time || 'N/A' %></span>
                        <small>(Oras ng Interbyu)</small>
                    </td>
                </tr>
                <tr>
                    <td>Name of Informant: 
                        <span class="data-field"><%= intake.informant_name || 'N/A' %></span>
                        <small>(Pangalan ng Tagabantay)</small>
                    </td>
                    <td>Relation to Patient: 
                        <span class="data-field"><%= intake.informant_relation || 'N/A' %></span>
                        <small>(Relasyon sa Pasyente)</small>
                    </td>
                </tr>
                <tr>
                    <td>Address: 
                        <span class="data-field"><%= intake.informant_address || 'N/A' %></span>
                        <small>(Tirahan)</small>
                    </td>
                    <td>Contact Number: 
                        <span class="data-field"><%= intake.informant_contact || 'N/A' %></span>
                        <small>(Telepono - 11 digits)</small>
                    </td>
                </tr>
            </table>
        </div>

        <!-- A. Identifying Information -->
        <div class="section">
            <div class="section-title">A. IDENTIFYING INFORMATION</div>
            
            <div style="margin-bottom: 10px;">
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 10px;">
                    <div>
                        <div style="font-size: 10px;">Last Name</div>
                        <div class="data-field"><%= intake.last_name || 'N/A' %></div>
                    </div>
                    <div>
                        <div style="font-size: 10px;">First Name</div>
                        <div class="data-field"><%= intake.first_name || 'N/A' %></div>
                    </div>
                    <div>
                        <div style="font-size: 10px;">Middle Name</div>
                        <div class="data-field"><%= intake.middle_name || 'N/A' %></div>
                    </div>
                    <div>
                        <div style="font-size: 10px;">Extension</div>
                        <div class="data-field"><%= intake.extension || 'N/A' %></div>
                    </div>
                </div>
                
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 10px;">
                    <div>
                        <div style="font-size: 10px;">Sex</div>
                        <div class="data-field"><%= intake.sex || 'N/A' %></div>
                    </div>
                    <div>
                        <div style="font-size: 10px;">Date of Birth</div>
                        <div class="data-field"><%= intake.birthdate ? new Date(intake.birthdate).toLocaleDateString() : 'N/A' %></div>
                    </div>
                    <div>
                        <div style="font-size: 10px;">Age</div>
                        <div class="data-field"><%= intake.age || 'N/A' %></div>
                    </div>
                </div>
                
                <div>
                    <div style="font-size: 10px;">Place of Birth</div>
                    <div class="data-field"><%= intake.birth_place || 'N/A' %></div>
                </div>
            </div>

            <div style="margin: 10px 0;">
                <div style="font-size: 10px;">Permanent Address</div>
                <div class="data-field" style="width: 100%;"><%= intake.permanent_address || 'N/A' %></div>
            </div>

            <div style="margin: 10px 0;">
                <div style="font-size: 10px;">Present Address</div>
                <div class="data-field" style="width: 100%;"><%= intake.present_address || 'N/A' %></div>
            </div>

            <div style="margin: 10px 0;">
                <div style="font-size: 10px;">Civil Status</div>
                <div class="data-field"><%= intake.civil_status || 'N/A' %></div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin: 10px 0;">
                <div>
                    <div style="font-size: 10px;">Religion</div>
                    <div class="data-field"><%= intake.religion || 'N/A' %></div>
                </div>
                <div>
                    <div style="font-size: 10px;">Nationality</div>
                    <div class="data-field"><%= intake.nationality || 'N/A' %></div>
                </div>
            </div>

            <div style="margin: 10px 0;">
                <div style="font-size: 10px;">Highest Educational Attainment</div>
                <div class="data-field" style="color: blue; font-weight: bold;">
                    <%= intake.education || 'N/A' %>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin: 10px 0;">
                <div>
                    <div style="font-size: 10px;">Occupation</div>
                    <div class="data-field"><%= intake.occupation || 'N/A' %></div>
                </div>
                <div>
                    <div style="font-size: 10px;">Monthly Income (PHP)</div>
                    <div class="data-field">
                        <%= intake.monthly_income ? '&#8369;' + parseFloat(intake.monthly_income).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                    </div>
                </div>
            </div>
        </div>

        <!-- B. Family Composition -->
        <div class="section">
            <div class="section-title">B. FAMILY COMPOSITION <small>(Komposisyon ng Pamilya)</small></div>
            <table>
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Last/First/Middle Name</th>
                        <th>Sex</th>
                        <th>Age</th>
                        <th>Civil Status</th>
                        <th>Relation</th>
                        <th>Education</th>
                        <th>Occupation</th>
                        <th>Income</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (familyMembers && familyMembers.length > 0) { %>
                        <% familyMembers.forEach((member, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= member.name || 'N/A' %></td>
                                <td><%= member.sex || 'N/A' %></td>
                                <td><%= member.age || 'N/A' %></td>
                                <td><%= member.civil_status || 'N/A' %></td>
                                <td><%= member.relation || 'N/A' %></td>
                                <td><%= member.education || 'N/A' %></td>
                                <td><%= member.occupation || 'N/A' %></td>
                                <td>
                                                <%= member.income ? '&#8369;' + parseFloat(member.income).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="9" style="text-align: center; padding: 20px; color: #666;">No family members added</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- C. Total Family Income -->
        <div class="section page-break">
            <div class="section-title">C. TOTAL FAMILY INCOME</div>
            <table style="width:100%; border-collapse:collapse;">
                <tr>
                    <td style="width:60%; vertical-align:top;">
                        <b>Breakdown:</b><br><br>
                        House / Lot: 
                        <span class="data-field"><%= intake.house_lot || 'N/A' %></span>
                        <br><br>
                        Light Source: 
                        <span class="data-field"><%= intake.light_source || 'N/A' %></span>
                        <br><br>
                        Water Source: 
                        <span class="data-field"><%= intake.water_source || 'N/A' %></span>
                        <br><br>
                        Artesian Well: 
                        <span class="data-field"><%= intake.artesian_well || 'N/A' %></span>
                        <br><br>
                        Water District: 
                        <span class="data-field"><%= intake.water_district || 'N/A' %></span>
                    </td>
                    <td style="width:40%; vertical-align:top;">
                        <b>Expenses:</b><br><br>
                        Food: 
                        <span class="data-field">
                        <%= intake.expenses_food ? '&#8369;' + parseFloat(intake.expenses_food).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Education: 
                        <span class="data-field">
                        <%= intake.expenses_education ? '&#8369;' + parseFloat(intake.expenses_education).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Clothing: 
                        <span class="data-field">
                        <%= intake.expenses_clothing ? '&#8369;' + parseFloat(intake.expenses_clothing).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Transportation: 
                        <span class="data-field">
                        <%= intake.expenses_transportation ? '&#8369;' + parseFloat(intake.expenses_transportation).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Househelp: 
                        <span class="data-field">
                        <%= intake.expenses_househelp ? '&#8369;' + parseFloat(intake.expenses_househelp).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Medical Expenditure: 
                        <span class="data-field">
                        <%= intake.expenses_medical ? '&#8369;' + parseFloat(intake.expenses_medical).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Insurance Premium: 
                        <span class="data-field">
                        <%= intake.expenses_insurance ? '&#8369;' + parseFloat(intake.expenses_insurance).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span><br>
                        Others: 
                        <span class="data-field">
                        <%= intake.expenses_others ? '&#8369;' + parseFloat(intake.expenses_others).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                        </span>
                    </td>
                </tr>
            </table>
        </div>

        <!-- D. Problem Presented -->
        <div class="section">
            <div class="section-title">D. PROBLEM PRESENTED</div>
            <table>
                <tr>
                    <td>
                        <span class="checkbox-item <%= intake.problem_health ? 'checked' : '' %>">
                            Health Condition of Patient (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_health_specify || 'N/A' %></span>
                    </td>
                    <td>
                        <span class="checkbox-item <%= intake.problem_economic ? 'checked' : '' %>">
                            Economic Resources (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_economic_specify || 'N/A' %></span>
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="checkbox-item <%= intake.problem_food ? 'checked' : '' %>">
                            Food/Nutrition (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_food_specify || 'N/A' %></span>
                    </td>
                    <td>
                        <span class="checkbox-item <%= intake.problem_housing ? 'checked' : '' %>">
                            Housing (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_housing_specify || 'N/A' %></span>
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="checkbox-item <%= intake.problem_employment ? 'checked' : '' %>">
                            Employment (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_employment_specify || 'N/A' %></span>
                    </td>
                    <td>
                        <span class="checkbox-item <%= intake.problem_others ? 'checked' : '' %>">
                            Others (specify)
                        </span>
                        <span class="data-field"><%= intake.problem_others_specify || 'N/A' %></span>
                    </td>
                </tr>
            </table>

            <p style="margin-top:15px; font-size:11px; text-align:justify; font-weight: bold;">
                AKO SI, <span class="data-field" style="width:60%;"><%= intake.client_name_signature || 'N/A' %></span>, 
                AY NAGPAPATUNAY NA ANG IMPORMASYON NAKASULAT SA IBABAW AY TOTOO AT TAMA. 
                PINAPAHINTULUTAN KO DIN MAIBAHAGI ANG MGA NATURANG IMPORMASYON SA IBA PANG AHENSYA NG GOBYERNO PARA SA ANUMANG NAAANGKOP NA PAG GAMIT.
            </p>

            <table class="no-border" style="margin-top:20px; width:100%;">
                <tr>
                    <td style="width:70%; text-align:center; vertical-align:bottom;">
                        <div class="signature-box"></div>
                        <div style="margin-top:4px; font-weight: bold;">Pangalan at Lagda ng Kliyente</div>
                    </td>
                    <td style="width:30%; text-align:center; vertical-align:bottom;">
                        <div class="thumbmark-box"></div>
                        <div style="margin-top:4px; font-weight: bold;">Thumb Mark</div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- E. Social Worker's Assessment -->
        <div class="section">
            <div class="section-title">E. SOCIAL WORKER'S ASSESSMENT</div>
            <table>
                <tr>
                    <td>
                        <span class="checkbox-item <%= intake.assessment_financially_capable ? 'checked' : '' %>">
                            Family is financially capable to support the present health needs of the patient, due to previous medical expenses, thus they need medical assistance.
                        </span>
                    </td>
                    <td>
                        <span class="checkbox-item <%= intake.assessment_lack_resources ? 'checked' : '' %>">
                            Family lack the necessary resources to support the health needs of the patient thus in needs of medical assistance.
                        </span>
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="checkbox-item <%= intake.assessment_medical_checkup ? 'checked' : '' %>">
                            Patient needs to undergo a medical check-up as basic school requirements/employment requirements, thus he/she decided to request for a medical assistance.
                        </span>
                    </td>
                    <td>
                        <span class="checkbox-item <%= intake.assessment_resources_exhausted ? 'checked' : '' %>">
                            Family resources were exhausted due to costly medical treatment and could not support the present health needs of the patient and in needs of medical assistance.
                        </span>
                    </td>
                </tr>
            </table>
        </div>

        <!-- F. Recommendations -->
        <div class="section">
            <div class="section-title">F. RECOMMENDATIONS</div>
            <table style="width:100%; border-collapse:collapse; font-size:11px;">
                <thead>
                    <tr>
                        <th style="width:36%; border:1px solid #000; padding:6px; text-align:left; font-weight:bold;">TYPE OF ASSISTANCE</th>
                        <th style="width:18%; border:1px solid #000; padding:6px; text-align:center; font-weight:bold;">AMOUNT OF ASSISTANCE</th>
                        <th style="width:30%; border:1px solid #000; padding:6px; text-align:center; font-weight:bold;">MODE OF ASSISTANCE</th>
                        <th style="width:16%; border:1px solid #000; padding:6px; text-align:center; font-weight:bold;">FUND SOURCE</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="border:1px solid #000; vertical-align:top; padding:8px;">
                            <div style="font-weight:bold; margin-bottom:6px;">EA for Medical Assistance</div>
                            <span class="checkbox-item <%= intake.recommendation_hospital_bill ? 'checked' : '' %>">
                                Hospital Bill
                            </span><br>
                            <span class="checkbox-item <%= intake.recommendation_lab_diagnostic ? 'checked' : '' %>">
                                Laboratory and Diagnostic Procedures
                            </span><br>
                            <span class="checkbox-item <%= intake.recommendation_medical_supplies ? 'checked' : '' %>">
                                Medical Supplies
                            </span>
                        </td>
                        <td style="border:1px solid #000; vertical-align:top; padding:8px; height:120px;">
                            <span class="data-field" style="width:100%; display: block; text-align: center; font-size: 14px; font-weight: bold;">
                                        <%= intake.recommendation_amount ? '&#8369;' + parseFloat(intake.recommendation_amount).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                            </span>
                        </td>
                        <td style="border:1px solid #000; vertical-align:middle; padding:8px; text-align:center;">
                            <span class="data-field"><%= intake.recommendation_mode || 'N/A' %></span>
                        </td>
                        <td style="border:1px solid #000; vertical-align:middle; padding:8px; text-align:center; font-weight:bold;">
                            <span class="data-field"><%= intake.recommendation_fund_source || 'N/A' %></span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Bottom Boxes -->
        <div class="section" style="display:flex; justify-content:space-between; margin-top:15px;">
            <div style="width:48%; text-align:center; border:1px solid #000; padding:15px;">
                Interviewed by: <br><br>
                <span class="data-field" style="width:80%;"><%= intake.interviewed_by || 'N/A' %></span>
                <br>
                Name and signature of Medical Social Worker
            </div>
            <div style="width:48%; text-align:center; border:1px solid #000; padding:15px;">
                Reviewed and Approved by: <br><br>
                <span class="data-field" style="width:80%;"><%= intake.approved_by || 'N/A' %></span>
                <br>
                Lic. No. 0031864<br>
                OIC: MEDICAL SOCIAL SERVICE
            </div>
        </div>

        <!-- Additional Information -->
        <div class="section">
            <div class="section-title">ADDITIONAL INFORMATION</div>
            <table class="no-border">
                <tr>
                    <td style="width:50%;">
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Medical Assistance Needed:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.medical_assistance || 'N/A' %></div>
                        </div>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Medical Concern:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.medical_concern || 'N/A' %></div>
                        </div>
                    </td>
                    <td style="width:50%;">
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Contact:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.patient_contact || 'N/A' %></div>
                        </div>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Email:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.patient_email || 'N/A' %></div>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Occupation:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.patient_occupation || 'N/A' %></div>
                        </div>
                    </td>
                    <td>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Income:</div>
                            <div class="data-field" style="width: 100%;">
                        <%= intake.patient_income ? '&#8369;' + parseFloat(intake.patient_income).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '&#8369;0.00' %>
                            </div>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Nationality:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.patient_nationality || 'N/A' %></div>
                        </div>
                    </td>
                    <td>
                        <div style="margin-bottom: 10px;">
                            <div style="font-size: 10px;">Patient Civil Status:</div>
                            <div class="data-field" style="width: 100%;"><%= intake.patient_civil_status || 'N/A' %></div>
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Admin Footer -->
        <div class="admin-info" style="margin-top: 20px;">
            <h3>ADMIN NOTES</h3>
            <div style="font-size: 11px; color: #666;">
                <p><strong>Document Path:</strong> <%= intake.document_path || 'No document uploaded' %></p>
                <p><strong>View Count:</strong> This document has been viewed by admin.</p>
                <p><strong>System ID:</strong> <%= intake.id %></p>
                <p><strong>Database Entry Created:</strong> <%= new Date(intake.created_at).toLocaleString() %></p>
                <p><strong>Last Modified:</strong> <%= new Date(intake.updated_at).toLocaleString() %></p>
            </div>
        </div>
    </div>

    <script>
        function downloadAsPDF() {
            // Create a new window for printing
            const printWindow = window.open('', '_blank');
            printWindow.document.write(`
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Intake Sheet - <%= intake.first_name %> <%= intake.last_name %></title>
                    <link rel="stylesheet" href="${window.location.origin}/css/admin/print-intake-export.css">
                </head>
                <body>
                    <div style="text-align: center; margin-bottom: 20px; color: #666;">
                        <h3>EXPORTED INTAKE SHEET</h3>
                        <p>Generated on: ${new Date().toLocaleString()}</p>
                        <p>Patient: <%= intake.first_name %> <%= intake.last_name %></p>
                        <p>Intake ID: <%= intake.id %></p>
                    </div>
                    ${document.querySelector('.container').innerHTML}
                </body>
                </html>
            `);
            printWindow.document.close();
            setTimeout(() => {
                printWindow.print();
            }, 500);
        }

        // Auto-print if specified
        if (window.location.search.includes('print=true')) {
            window.print();
        }
