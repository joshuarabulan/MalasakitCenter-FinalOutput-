<!-- YouTube hover autoplay -->
<script>
    function postToPlayer(player, command) {
        if (player && player.contentWindow) {
            player.contentWindow.postMessage(JSON.stringify({ event:'command', func:command, args:[] }), "*");
        }
    }
    document.querySelectorAll('.youtube-container').forEach(container => {
        const iframe = container.querySelector('iframe');
        container.addEventListener('mouseenter', () => postToPlayer(iframe, 'playVideo'));
        container.addEventListener('mouseleave', () => postToPlayer(iframe, 'pauseVideo'));
    });
</script>

<!-- ===== PROCESS ===== -->
<section id="process" class="process-section py-24">
    <div class="container mx-auto px-4">
        <div class="text-center mb-16 reveal">
            <p class="section-eyebrow">How It Works</p>
