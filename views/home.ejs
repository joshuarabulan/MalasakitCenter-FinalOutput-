        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
            <div class="connector"></div>

            <div class="step-card reveal reveal-delay-1">
                <div class="step-num step-num-blue">1</div>
                <h3 class="font-bold text-gray-900 mb-2">Document Verification</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Submit required medical documents and valid identification</p>
                <div class="mt-4 inline-flex items-center gap-1.5 text-blue-600 text-xs font-semibold bg-blue-50 px-3 py-1.5 rounded-full">
                    <i class='bx bx-time-five'></i> 1-2 days
                </div>
            </div>

            <div class="step-card reveal reveal-delay-2">
                <div class="step-num step-num-blue">2</div>
                <h3 class="font-bold text-gray-900 mb-2">Eligibility Check</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Automatic assessment of qualification criteria and needs</p>
                <div class="mt-4 inline-flex items-center gap-1.5 text-blue-600 text-xs font-semibold bg-blue-50 px-3 py-1.5 rounded-full">
                    <i class='bx bx-time-five'></i> 1 day
                </div>
            </div>

            <div class="step-card reveal reveal-delay-3">
                <div class="step-num step-num-blue">3</div>
                <h3 class="font-bold text-gray-900 mb-2">Approval Process</h3>
                <p class="text-gray-500 text-sm leading-relaxed">Quick review by our dedicated medical assistance team</p>
